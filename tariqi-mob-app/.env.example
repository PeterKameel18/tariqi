# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/tariqi

# JWT secret for authentication (generate a strong random string)
JWT_SECRET=your-jwt-secret-here

# OpenRouteService API key (https://openrouteservice.org/)
ORS_API_KEY=your-ors-api-key-here

# Stripe secret key for card payments (https://stripe.com/)
STRIPE_SECRET_KEY=sk_test_your-stripe-key-here

# Server port (optional, defaults to 5000)
PORT=5000
