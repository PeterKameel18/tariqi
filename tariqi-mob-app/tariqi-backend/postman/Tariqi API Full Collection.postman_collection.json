	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"function getRandomCoordinate(min, max) {",
					"    return min + Math.random() * (max - min);",
					"}",
					"function getRandomPhoneNumber() {",
					"    return Math.floor(Math.random() * 9000000000) + 1000000000;",
					"}",
					"function getRandomEmail(role) {",
					"    const timestamp = new Date().getTime();",
					"    return `test_${role}_${timestamp}@example.com`;",
					"}",
					"if (pm.info.requestName.includes('Signup (Client)')) {",
					"    const email = getRandomEmail('client');",
					"    const phoneNumber = getRandomPhoneNumber();",
					"    const password = 'password';",
					"    pm.variables.set('test_client_email', email);",
					"    pm.variables.set('test_client_phone', phoneNumber);",
					"    pm.variables.set('test_client_password', password);",
					"    if (pm.request.body && pm.request.body.raw) {",
					"        const requestBody = JSON.parse(pm.request.body.raw);",
					"        requestBody.email = email;",
					"        requestBody.phoneNumber = phoneNumber;",
					"        requestBody.password = password;",
					"        pm.request.body.raw = JSON.stringify(requestBody);",
					"    }",
					"}",
					"if (pm.info.requestName.includes('Signup (Driver)')) {",
					"    const email = getRandomEmail('driver');",
					"    const phoneNumber = getRandomPhoneNumber();",
					"    const password = 'password';",
					"    pm.variables.set('test_driver_email', email);",
					"    pm.variables.set('test_driver_phone', phoneNumber);",
					"    pm.variables.set('test_driver_password', password);",
					"    if (pm.request.body && pm.request.body.raw) {",
					"        const requestBody = JSON.parse(pm.request.body.raw);",
					"        requestBody.email = email;",
					"        requestBody.phoneNumber = phoneNumber;",
					"        requestBody.password = password;",
					"        pm.request.body.raw = JSON.stringify(requestBody);",
					"    }",
					"}",
					"if (pm.info.requestName === 'Create Ride') {",
					"    const startLat = getRandomCoordinate(29.9792, 30.0444);",
					"    const startLng = getRandomCoordinate(31.1342, 31.2357);",
					"    const endLat = getRandomCoordinate(29.9792, 30.0444);",
					"    const endLng = getRandomCoordinate(31.1342, 31.2357);",
					"    pm.variables.set('start_lat', startLat);",
					"    pm.variables.set('start_lng', startLng);",
					"    pm.variables.set('end_lat', endLat);",
					"    pm.variables.set('end_lng', endLng);",
					"    const body = {",
					"      route: [",
					"        { lat: Number(startLat), lng: Number(startLng) },",
					"        { lat: Number(endLat), lng: Number(endLng) }",
					"      ],",
					"      availableSeats: 3",
					"    };",
					"    pm.request.body.raw = JSON.stringify(body);",
					"}",
					"if (pm.info.requestName === 'Create Join Request') {",
					"    const startLat = pm.variables.get('start_lat');",
					"    const startLng = pm.variables.get('start_lng');",
					"    const endLat = pm.variables.get('end_lat');",
					"    const endLng = pm.variables.get('end_lng');",
					"    const rideId = pm.variables.get('ride_id');",
					"    const body = {",
					"      rideId: rideId,",
					"      pickup: { lat: Number(startLat), lng: Number(startLng) },",
					"      dropoff: { lat: Number(endLat), lng: Number(endLng) }",
					"    };",
					"    pm.request.body.raw = JSON.stringify(body);",
					"}",
					"(function() {",
					"    const needsRideId = [",
					"        'Get Ride Data', 'Get Pending Join Requests', 'End Ride', 'End Client Ride',",
					"        'Create Chat Room', 'Get Chat Messages', 'Send Message', 'Create Join Request',",
					"        'Approve/Reject Join Request', 'Pickup Passenger', 'Dropoff Passenger',",
					"        'Update Payment Status', 'Initialize Payment', 'Confirm Cash Payment',",
					"        'Get Payment Details'",
					"    ];",
					"    const needsRequestId = [",
					"        'Approve/Reject Join Request', 'Pickup Passenger', 'Dropoff Passenger',",
					"        'Update Payment Status', 'Cancel Join Request'",
					"    ];",
					"    const needsPaymentId = [",
					"        'Confirm Cash Payment', 'Get Payment Details'",
					"    ];",
					"    const reqName = pm.info.requestName;",
					"    if (needsRideId.some(n => reqName.includes(n))) {",
					"        const val = pm.variables.get('ride_id');",
					"        if (!val || val.includes('your_') || val.length !== 24 || !/^[a-fA-F0-9]{24}$/.test(val)) {",
					"            console.warn(`Aborting: ride_id is not a valid ObjectId: ${val}`);",
					"            postman.setNextRequest(null);",
					"        }",
					"    }",
					"    if (needsRequestId.some(n => reqName.includes(n))) {",
					"        const val = pm.variables.get('request_id');",
					"        if (!val || val.includes('your_') || val.length !== 24 || !/^[a-fA-F0-9]{24}$/.test(val)) {",
					"            console.warn(`Aborting: request_id is not a valid ObjectId: ${val}`);",
					"            postman.setNextRequest(null);",
					"        }",
					"    }",
					"    if (needsPaymentId.some(n => reqName.includes(n))) {",
					"        const val = pm.variables.get('payment_id');",
					"        if (!val || val.includes('your_') || val.length !== 24 || !/^[a-fA-F0-9]{24}$/.test(val)) {",
					"            console.warn(`Aborting: payment_id is not a valid ObjectId: ${val}`);",
					"            postman.setNextRequest(null);",
					"        }",
					"    }",
					"})();"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (pm.info.requestName.includes('Signup (Driver)') || pm.info.requestName.includes('Login (Driver)')) {",
					"    const response = pm.response.json();",
					"    if (response.token) { pm.variables.set('driver_token', response.token); pm.variables.set('driver_id', response.id); }",
					"}",
					"if (pm.info.requestName.includes('Signup (Client)') || pm.info.requestName.includes('Login (Client)')) {",
					"    const response = pm.response.json();",
					"    if (response.token) { pm.variables.set('client_token', response.token); pm.variables.set('client_id', response.id); }",
					"}",
					"if (pm.info.requestName.includes('Create Ride')) {",
					"    const response = pm.response.json();",
					"    if (response.ride && response.ride._id) { pm.variables.set('ride_id', response.ride._id); pm.execution.setNextRequest('Create Join Request'); } else { pm.execution.setNextRequest(null); }",
					"}",
					"if (pm.info.requestName.includes('Create Join Request')) {",
					"    const response = pm.response.json();",
					"    if (response._id) { pm.variables.set('request_id', response._id); pm.execution.setNextRequest('Get Pending Join Requests'); } else { pm.execution.setNextRequest(null); }",
					"}",
					"if (pm.info.requestName.includes('Get Pending Join Requests')) {",
					"    const response = pm.response.json();",
					"    if (response && response.length > 0) { pm.execution.setNextRequest('Approve/Reject Join Request'); } else { pm.execution.setNextRequest(null); }",
					"}",
					"if (pm.info.requestName.includes('Approve/Reject Join Request')) { pm.execution.setNextRequest('Initialize Payment (Card)'); }",
					"if (pm.info.requestName.includes('Initialize Payment (Card)')) {",
					"    const response = pm.response.json();",
					"    if (response.paymentId) {",
					"        pm.variables.set('payment_id_card', response.paymentId);",
					"    } else if (response._id) {",
					"        pm.variables.set('payment_id_card', response._id);",
					"    } else if (response.id) {",
					"        pm.variables.set('payment_id_card', response.id);",
					"    }",
					"    pm.execution.setNextRequest('Pickup Passenger');",
					"}",
					"if (pm.info.requestName.includes('Initialize Payment (Cash)')) {",
					"    const response = pm.response.json();",
					"    if (response._id) {",
					"        pm.variables.set('payment_id_cash', response._id);",
					"    } else if (response.id) {",
					"        pm.variables.set('payment_id_cash', response.id);",
					"    }",
					"    pm.execution.setNextRequest('Confirm Cash Payment');",
					"}",
					"if (pm.info.requestName.includes('Pickup Passenger')) { pm.execution.setNextRequest('Dropoff Passenger'); }",
					"if (pm.info.requestName.includes('Dropoff Passenger')) { pm.execution.setNextRequest('Get Payment History'); }",
					"if (pm.info.requestName.includes('Get Payment History')) { pm.execution.setNextRequest('Get Payment Details'); }",
					"if (pm.info.requestName.includes('Get Payment Details')) {",
					"    console.log('payment_id before Get Payment Details:', pm.variables.get('payment_id'));",
					"    pm.execution.setNextRequest('End Client Ride');",
					"}",
					"if (pm.info.requestName.includes('End Client Ride')) { pm.execution.setNextRequest('End Ride'); }",
