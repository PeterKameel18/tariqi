									"const response = pm.response.json();",
									"if (response.paymentId) { pm.variables.set('payment_id_card', response.paymentId); }",
									"else if (response._id) { pm.variables.set('payment_id_card', response._id); }",
									"else if (response.id) { pm.variables.set('payment_id_card', response.id); }",
